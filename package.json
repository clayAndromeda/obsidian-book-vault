{
	"name": "obsidian-book-vault",
	"version": "1.0.2",
	"description": "Obsidian plugin for creating book notes from Google Books",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"deploy": "npm run build && node --env-file=.env deploy.mjs",
		"version": "node version-bump.mjs && git add manifest.json"
	},
	"keywords": [],
	"author": "clayAndromeda",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"builtin-modules": "^3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	}
}
